# Настройки Django
DJANGO_SECRET_KEY="your-super-secret-key-change-it-in-production"
DJANGO_DEBUG=True

# Настройки базы данных (по умолчанию используется SQLite)
# DB_NAME=db.sqlite3

# Разрешить синхронные вызовы Django в асинхронном Flet (ОБЯЗАТЕЛЬНО true ДЛЯ DESKTOP)
DJANGO_ALLOW_ASYNC_UNSAFE=true

# Настройки логирования
LOG_LEVEL=DEBUG                     # DEBUG INFO
LOG_PATH=logs/app.log
LOG_ROTATION=5 MB
LOG_RETENTION=15 days
LOG_COMPRESSION=zip
LOG_SERIALIZE=False 	            # True - JSON

LOG_PATH_ERRORS=logs/errors.log
LOG_SERIALIZE_ERRORS=False          # True - JSON
